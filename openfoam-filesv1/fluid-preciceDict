FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      preciceDict;
}

// ---- preCICE adapter configuration for pimpleFoam (fluid) ----

preciceConfig "../precice-config.xml";

participant Fluid;

modules (FSI);

interfaces
{
    Interface1
    {
        mesh              Fluid-Mesh;
        patches           (interface);    // <-- your coupling patch name
        locations         faceCenters;

        readData
        (
            Displacement
        );

        writeData
        (
            Force
        );
    }
}

FSI
{
    // For incompressible solvers, provide rho and nu
    rho rho [1 -3 0 0 0 0 0] 1000;
    // nu is typically read from transportProperties, but can be set here
}
