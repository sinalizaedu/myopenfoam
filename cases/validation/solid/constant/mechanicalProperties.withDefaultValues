planeStress     yes;

mechanical      1 ( steel { type linearElastic ; rho rho [ 1 -3 0 0 0 0 0 ] 7800 ; E E [ 1 -1 -2 0 0 0 0 ] 2e+11 ; nu nu [ 0 0 0 0 0 0 0 ] 0.3 ; solvePressureEqn false ; pressureSmoothingScaleFactor 100 ; } ; );


